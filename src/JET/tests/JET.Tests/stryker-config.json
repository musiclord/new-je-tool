{
  "stryker-config": {
    "project": "JET.csproj",
    "mutate": [
      "**/Domain/**/*.cs",
      "**/Application/**/*.cs",
      "!**/*.Designer.cs",
      "!**/Migrations/**/*.cs"
    ],
    "coverage-analysis": "perTest",
    "reporters": ["html", "json", "cleartext"],
    "thresholds": { "high": 80, "low": 60, "break": 0 }
  }
}
